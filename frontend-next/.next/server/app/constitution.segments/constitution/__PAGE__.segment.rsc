e:["$","section",null,{"id":"article-12","className":"constitution-section","children":[["$","h2",null,{"children":[["$","span",null,{"className":"article-number","children":"অনুচ্ছেদ–১২"}]," গঠনতন্ত্রের পরিমার্জন, পরিবর্ধন ও সংশোধন"]}],["$","ol",null,{"children":[["$","li",null,{"children":"গঠনতন্ত্রের পরিমার্জন, পরিবর্ধন, সংশোধন অথবা কোন নতুন অনুচ্ছেদ সংযুক্তির প্রয়োজন দেখা দিলে নির্বাহী পরিষদের সকল সদস্যের উপস্থিতিতে একটি নির্বাহী সভা আহ্বান করা হবে।"}],["$","li",null,{"children":"গঠনতন্ত্র সংক্রান্ত প্রস্তাবসমূহ নিয়ে বিস্তারিত আলোচনা শেষে উপস্থিত সদস্যদের কমপক্ষে দুই-তৃতীয়াংশ সংখ্যাগরিষ্ঠ মতামতের ভিত্তিতে সংশ্লিষ্ট সংশোধনীসমূহ খসড়া আকারে লিপিবদ্ধ করা হবে।"}],["$","li",null,{"children":"উক্ত খসড়া সভাপতি ও সাধারণ সম্পাদক প্রয়োজনবোধে সাবেক শিক্ষার্থীদের সঙ্গে পরামর্শক্রমে চূড়ান্তভাবে পরিমার্জন, পরিবর্ধন ও সংশোধন করবেন এবং প্রয়োজন অনুযায়ী নতুন অনুচ্ছেদ সংযুক্ত করে তা লিপিবদ্ধ করবেন।"}]]}]]}]
f:["$","section",null,{"id":"article-13","className":"constitution-section","children":[["$","h2",null,{"children":[["$","span",null,{"className":"article-number","children":"অনুচ্ছেদ ১৩"}]," নির্বাচন"]}],["$","p",null,{"children":"তিতাস- ঢাকা বিশ্ববিদ্যালয়স্থ ব্রাহ্মণবাড়িয়া জেলা ছাত্রকল্যাণ পরিষদ প্রতি এক বছর অন্তর সকল সদস্যের প্রত্যক্ষ ভোটের মাধ্যমে সভাপতি ও সাধারণ সম্পাদক নির্বাচিত করবে। বর্তমান কমিটির মেয়াদ পূর্ণ হওয়ার এক মাস পূর্বে নতুন কমিটি গঠন করার নিমিত্ত নির্বাচন প্রক্রিয়া শুরু করবে।"}],["$","h3",null,{"children":"১৩.ক। নির্বাচন কমিশন ও এর কার্যাবলী"}],["$","h4",null,{"children":"১৩.ক (১) নির্বাচন কমিশনের সদস্য"}],["$","ol",null,{"children":["$","li",null,{"children":"সর্বশেষ দুইটি কমিটি (বর্তমান কমিটি সহ) সভাপতি ও সাধারণ সম্পাদক পদাধিকারবলে পরবর্তী কমিটির নির্বাচন কমিশনের সদস্য হিসেবে থাকবেন।"}]}],["$","h4",null,{"children":"১৩.ক (২) নির্বাচন কমিশনের কার্যাবলী"}],["$","ol",null,{"className":"bn-list","children":[["$","li",null,{"children":[["$","strong",null,{"children":"ক।"}]," নির্বাচন কমিশন নির্বাচনী তফসিল ঘোষণার পর থেকে নির্বাচনের সকল কার্যক্রম সম্পন্ন করে নির্বাচনে বিজয়ীকে পূর্বের সকল শর্ত মান্য করে দায়িত্ব হস্তান্তর পর্যন্ত দায়িত্বশীল থাকবেন।"]}],["$","li",null,{"children":[["$","strong",null,{"children":"খ।"}]," প্রার্থীতা যাচাই-বাছাই এবং মার্কা/ব্যালট নির্ধারণ নির্বাচন কমিশনের দায়িত্ব।"]}],["$","li",null,{"children":[["$","strong",null,{"children":"গ।"}]," উল্লিখিত শর্তসাপেক্ষ যারা প্রার্থীর জন্য আবেদন করবেন, তাদের বিস্তারিত তথ্য যাচাই-বাছাই পরবর্তী নির্বাচন কমিশন প্রার্থীর তালিকা প্রকাশ করবে। যাচাই-বাছাইয়ের ক্ষেত্রে চতুর্থ বর্ষ এবং মাস্টার্সের শিক্ষার্থীদের দেওয়া মতামত এবং তথ্য বিবেচনা করবে।"]}],["$","li",null,{"children":[["$","strong",null,{"children":"ঘ।"}]," নির্বাচন পূর্ববর্তী প্রস্তুতিমূলক মিটিংয়ে সাধারণ সদস্য এবং প্রার্থীদের উপস্থিতিতে মার্কা/ব্যালট নির্ধারিত হবে।"]}],["$","li",null,{"children":[["$","strong",null,{"children":"ঙ।"}]," নির্বাচনী প্রচার-প্রচারণা এবং প্রার্থীর ক্ষেত্রে কোন প্রার্থী নিয়ম-নীতির অবহেলা করলে তার বিরুদ্ধে নির্বাচন কমিশন দ্রুত ব্যবস্থা গ্রহণ করতে পারবে। প্রয়োজনে প্রার্থীতা বাতিল করতে পারবে।"]}],["$","li",null,{"children":[["$","strong",null,{"children":"চ।"}]," সুষ্ঠু এবং স্বচ্ছভাবে নির্বাচন কার্যক্রম পরিচালনার জন্য নির্বাচন কেন্দ্রে প্রতিটি প্রার্থীর ভোটারদের মধ্যে থেকে একজন এজেন্ট নিয়োগ করতে হবে। এজেন্টরা নির্বাচন কমিশনের সাথে ভোটিং প্রক্রিয়ায় সমন্বয় করবে। এজেন্টরা ভোটারদের নিশ্চয়তা থেকে ভোট গণনা পর্যন্ত সেই প্রার্থীর প্রতিনিধিত্ব হিসেবে কাজ করবে। নির্বাচন কমিশন এবং এজেন্টরা ভোট কেন্দ্রে প্রার্থীর বা অন্য কোনো প্রার্থীর অবস্থানে থাকতে পারবে না।"]}],["$","li",null,{"children":[["$","strong",null,{"children":"ছ।"}]," নির্বাচন আয়োজকের ক্ষেত্রে নির্বাচন কমিশন প্রয়োজনে ভলান্টিয়ার নিয়োগ করতে পারবে। সেই ক্ষেত্রে প্রথম থেকে তৃতীয় বর্ষ শিক্ষার্থীদের মধ্যে থেকে ভলান্টিয়ার নিয়োগ দেওয়া যাবে।"]}]]}],["$","h3",null,{"children":"১৩.খ। সভাপতি এবং সাধারণ সম্পাদক প্রার্থীর যোগ্যতা"}],["$","ol",null,{"className":"bn-list","children":[["$","li",null,{"children":[["$","strong",null,{"children":"ক।"}]," সভাপতি প্রার্থীর জন্য: মাস্টার্সের শিক্ষার্থী, সাধারণ সম্পাদক প্রার্থীর জন্য: চতুর্থ বর্ষ শিক্ষার্থী হবেন। এই ক্ষেত্রে ঢাকা বিশ্ববিদ্যালয়ে স্নাতক ভর্তির সেশনকে মানদণ্ড হিসেবে বিবেচনা করা হবে। প্রার্থী অবশ্যই অধ্যয়নরত হতে হবে।"]}],["$","li",null,{"children":[["$","strong",null,{"children":"খ।"}]," নির্বাচিত সভাপতি এবং সাধারণ সম্পাদক যদি কোন রাজনৈতিক দলের পদধারী হয়, সেই ক্ষেত্রে নির্বাচিত হয়ে দায়িত্ব গ্রহণের পূর্বে তার দলীয় পদ থেকে অব্যাহতি নিতে হবে। দলীয় পদ থেকে অব্যাহতি দিতে আপত্তি থাকলে দ্বিতীয় সর্বোচ্চ ভোট প্রাপ্ত প্রার্থী সেই পদে যোগ্য বিবেচিত হবে।"]}],["$","li",null,{"children":[["$","strong",null,{"children":"গ।"}]," নৈতিকভাবে পদক্ষেপহীন ব্যক্তি (মাদক, অশ্লীল এবং নারী কলঙ্কায় যুক্ত) প্রার্থী হিসেবে বিবেচিত হবে না। (নির্বাচন কমিশন প্রার্থী যাচাই-বাছাইয়ের ক্ষেত্রে বিবেচনা করবে)"]}],"$L14","$L15"]}],"$L16","$L17","$L18","$L19"]}]
